# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=appenvlo_holwert
DB_USER=db_holwert
DB_PASSWORD=your_secure_password_here

# Admin User Configuration (for setup-admin endpoint)
ADMIN_EMAIL=admin@holwert.nl
ADMIN_PASSWORD=your_secure_admin_password_here

# JWT Secret (generate a strong random string)
JWT_SECRET=your_jwt_secret_here

# PHP Proxy API Key (for db-proxy.php)
PHP_PROXY_API_KEY=your_secure_api_key_here

# Vercel Backend URL (optional, defaults to production)
BACKEND_URL=https://holwert-backend.vercel.app

# OpenWeather API key (voor weer-proxy; haal op via openweathermap.org)
OPENWEATHER_API_KEY=your_openweather_api_key_here
