# Environment Variables voor PHP Bestanden op FTP Server
# 
# INSTRUCTIES:
# 1. Kopieer dit bestand naar .env (zonder .example)
# 2. Vul de waarden in
# 3. Upload .env naar je FTP server (in dezelfde directory als db-proxy.php)
# 4. Zorg dat .env NIET publiek toegankelijk is (buiten webroot of via .htaccess beschermen)

# Database Configuratie
DB_HOST=localhost
DB_PORT=3306
DB_NAME=appenvlo_holwert
DB_USER=db_holwert
DB_PASSWORD=je_database_wachtwoord_hier

# PHP Proxy API Key (moet hetzelfde zijn als in Vercel)
# Haal de waarde op via: vercel env pull (in holwert-backend directory)
PHP_PROXY_API_KEY=je_api_key_hier
